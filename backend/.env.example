NODE_ENV=development
PORT=4000

# Database
DATABASE_URL=postgresql://zictia:zictia_dev_pass@localhost:5432/zictia_portal?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT (generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem)
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Password policy
PASSWORD_POLICY_MIN_LENGTH=10
PASSWORD_MAX_AGE_DAYS=90

# Session
SESSION_TIMEOUT_MINUTES=60

# Rate limits
RATE_LIMIT_AUTH=100
RATE_LIMIT_UNAUTH=20

# ZanMalipo
ZANMALIPO_BASE_URL=https://sandbox.zanmalipo.go.tz
ZANMALIPO_API_KEY=

# SMS
SMS_PRIMARY_PROVIDER=africastalking
SMS_PRIMARY_API_KEY=
SMS_FALLBACK_PROVIDER=
SMS_FALLBACK_API_KEY=
SMS_SENDER_ID=ZICTIA

# Email
SMTP_HOST=mail.zictia.go.tz
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@zictia.go.tz

# MinIO / S3-compatible storage
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=zictia
MINIO_SECRET_KEY=zictia_minio_pass
MINIO_BUCKET=zictia-portal

# Logging
LOG_LEVEL=info
